#!/usr/bin/env python3
"""Show Claude Code activity for a given day, derived from session logs."""

import argparse
import json
import os
import shutil
import sys
import urllib.error
import urllib.request
from datetime import datetime, timedelta, timezone
from pathlib import Path

PROJECTS_DIR = Path.home() / ".claude" / "projects"
SCAN_WINDOW_DAYS = 5
IDLE_SPLIT = timedelta(minutes=30)
# Reading buffer added when a session's last event is an assistant message:
# we have no close signal in the logs, so we credit the same ~3 min of idle
# time that triggers Claude's `away_summary`.
TRAILING_READ = timedelta(minutes=3)

CACHE_DIR = Path.home() / ".cache" / "wdid"
HAIKU_MODEL = "claude-haiku-4-5-20251001"
ANTHROPIC_API = "https://api.anthropic.com/v1/messages"


def parse_ts(s):
    if s.endswith("Z"):
        s = s[:-1] + "+00:00"
    return datetime.fromisoformat(s)


def extract_user_text(content):
    """Return prompt text if this user entry is a real user command, else None."""
    if isinstance(content, str):
        text = content
    elif isinstance(content, list):
        parts = []
        for block in content:
            if isinstance(block, dict):
                if block.get("type") == "tool_result":
                    return None
                if block.get("type") == "text":
                    parts.append(block.get("text", ""))
        text = "\n".join(parts)
    else:
        return None

    stripped = text.strip()
    if not stripped:
        return None
    if stripped.startswith("<local-command-caveat>"):
        return None
    if stripped.startswith("<system-reminder>"):
        return None
    # Slash-command wrappers: pull out just the command name (e.g. /commit).
    if stripped.startswith("<command-"):
        start = stripped.find("<command-name>")
        if start != -1:
            end = stripped.find("</command-name>", start)
            if end != -1:
                return stripped[start + len("<command-name>"):end].strip()
        return None
    return stripped


def collect_events(jsonl_path):
    """Yield (timestamp, kind, text, cwd) tuples for relevant events.

    `kind` is one of: "user", "assistant", "title".
    "title" carries an `ai-title` value, anchored to the nearest preceding
    timestamped event so it lands inside the right engagement session.
    """
    last_ts = None
    last_cwd = ""
    pending_titles = []  # ai-titles seen before any timestamped event
    try:
        with open(jsonl_path, "r", encoding="utf-8", errors="replace") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    e = json.loads(line)
                except json.JSONDecodeError:
                    continue

                etype = e.get("type")

                if etype == "ai-title":
                    title = (e.get("aiTitle") or "").strip()
                    if not title:
                        continue
                    if last_ts is None:
                        pending_titles.append(title)
                    else:
                        yield (last_ts, "title", title, last_cwd)
                    continue

                ts_raw = e.get("timestamp")
                if not ts_raw:
                    continue
                try:
                    ts = parse_ts(ts_raw)
                except ValueError:
                    continue

                cwd = e.get("cwd", "")
                last_ts = ts
                if cwd:
                    last_cwd = cwd
                for title in pending_titles:
                    yield (ts, "title", title, cwd)
                pending_titles.clear()

                if etype == "assistant":
                    yield (ts, "assistant", None, cwd)
                    continue

                if etype != "user":
                    continue

                if e.get("isMeta"):
                    continue
                msg = e.get("message") or {}
                text = extract_user_text(msg.get("content"))
                if text is None:
                    continue
                yield (ts, "user", text, cwd)
    except (OSError, IOError):
        return


def find_session_logs(now):
    cutoff = now - timedelta(days=SCAN_WINDOW_DAYS)
    cutoff_ts = cutoff.timestamp()
    if not PROJECTS_DIR.is_dir():
        return []
    logs = []
    for root, _dirs, files in os.walk(PROJECTS_DIR):
        # Subagent runs live under .../subagents/ and are part of their parent
        # session timewise — including them double-counts engagement.
        if "subagents" in Path(root).parts:
            continue
        for name in files:
            if not name.endswith(".jsonl"):
                continue
            p = Path(root) / name
            try:
                if p.stat().st_mtime >= cutoff_ts:
                    logs.append(p)
            except OSError:
                pass
    return logs


def split_into_sessions(events):
    """Split chronological events into engagement sessions on idle > 30 min.

    Splitting and gap timing are driven by user/assistant events only; title
    markers ride along inside whatever session contains their timestamp.
    """
    if not events:
        return []
    sessions = [[events[0]]]
    last_real = events[0][0] if events[0][1] != "title" else None
    for cur in events[1:]:
        ts, kind, *_ = cur
        if kind == "title":
            sessions[-1].append(cur)
            continue
        if last_real is not None and ts - last_real > IDLE_SPLIT:
            sessions.append([cur])
        else:
            sessions[-1].append(cur)
        last_real = ts
    return sessions


def session_summary(events_list, log_path):
    real_events = [e for e in events_list if e[1] != "title"]
    if not real_events:
        return None
    start = real_events[0][0]
    end = real_events[-1][0]
    engagement = timedelta(0)
    for prev, cur in zip(real_events, real_events[1:]):
        gap = cur[0] - prev[0]
        if gap <= IDLE_SPLIT:
            engagement += gap
    if real_events[-1][1] == "assistant":
        engagement += TRAILING_READ

    titles = [text for _ts, kind, text, _cwd in events_list
              if kind == "title" and text]
    user_texts = [text for _ts, kind, text, _cwd in events_list
                  if kind == "user" and text]
    fallback = next((t for t in user_texts if not t.startswith("/")), "")
    if not fallback:
        fallback = user_texts[0] if user_texts else ""
    cwd = next((c for _ts, _k, _t, c in events_list if c), "")

    return {
        "log_path": str(log_path),
        "start": start,
        "end": end,
        "engagement": engagement,
        "ai_title": titles[-1] if titles else "",
        "fallback_name": fallback,
        "user_texts": user_texts,
        "event_count": len(real_events),
        "cwd": cwd,
    }


def fmt_hhmm(td):
    total_min = int(td.total_seconds() // 60)
    return f"{total_min // 60:02d}:{total_min % 60:02d}"


def fmt_name(name, max_len):
    name = " ".join(name.split())  # collapse whitespace
    if max_len > 0 and len(name) > max_len:
        name = name[: max_len - 1] + "…"
    return name


def project_name(cwd):
    return Path(cwd).name if cwd else ""


def cache_path_for(date):
    return CACHE_DIR / f"titles-{date.isoformat()}.json"


def load_cache(date):
    p = cache_path_for(date)
    if not p.is_file():
        return {}
    try:
        return json.loads(p.read_text())
    except (OSError, json.JSONDecodeError):
        return {}


def save_cache(date, data):
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    p = cache_path_for(date)
    tmp = p.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(data, indent=2, sort_keys=True))
    tmp.replace(p)


def haiku_title(api_key, user_texts):
    """Ask Haiku for a concise session title. Returns string or None."""
    prompts = [t for t in user_texts if not t.startswith("/")] or user_texts
    if not prompts:
        return None
    blob = "\n\n---\n\n".join(prompts)[:8000]
    body = json.dumps({
        "model": HAIKU_MODEL,
        "max_tokens": 40,
        "system": (
            "You write concise session titles for a developer's coding logs. "
            "Given the user prompts from one Claude Code session, output a "
            "single 5-10 word title in sentence case that captures what was "
            "worked on. Output the title only — no quotes, no preamble, no "
            "trailing punctuation, no markdown, never copy text from the "
            "input verbatim. Never refuse, apologize, or ask for more "
            "context: with limited input, infer a best-effort title from "
            "what's there."
        ),
        "messages": [
            {"role": "user",
             "content": f"User prompts from the session:\n\n{blob}"},
        ],
    }).encode()
    req = urllib.request.Request(
        ANTHROPIC_API,
        data=body,
        headers={
            "x-api-key": api_key,
            "anthropic-version": "2023-06-01",
            "content-type": "application/json",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            payload = json.loads(resp.read())
    except (urllib.error.URLError, urllib.error.HTTPError, TimeoutError,
            json.JSONDecodeError) as exc:
        print(f"wdid: haiku call failed: {exc}", file=sys.stderr)
        return None
    for block in payload.get("content", []):
        if block.get("type") == "text":
            text = block.get("text", "").strip().strip('"').rstrip(".")
            # First line only — guard against models that ignore the
            # "no preamble / no markdown" instruction.
            text = text.splitlines()[0].strip() if text else ""
            if len(text) > 120:
                text = text[:119] + "…"
            return text or None
    return None


def main():
    ap = argparse.ArgumentParser(
        description="Show what you did on a given day, based on Claude Code session logs."
    )
    ap.add_argument(
        "date",
        nargs="?",
        help="Date in YYYY-MM-DD (default: today). Also accepts 'yesterday'.",
    )
    ap.add_argument(
        "--all",
        action="store_true",
        help="Show all sessions found within the scan window, not just one day.",
    )
    ap.add_argument(
        "--no-summarize",
        action="store_true",
        help="Skip Haiku-based summarization for sessions that lack an ai-title.",
    )
    args = ap.parse_args()

    now = datetime.now().astimezone()
    if args.date is None:
        target = now.date()
    elif args.date == "yesterday":
        target = (now - timedelta(days=1)).date()
    elif args.date == "today":
        target = now.date()
    else:
        try:
            target = datetime.strptime(args.date, "%Y-%m-%d").date()
        except ValueError:
            print(f"invalid date: {args.date!r} (expected YYYY-MM-DD)", file=sys.stderr)
            return 2

    logs = find_session_logs(now)
    all_sessions = []
    for log in logs:
        events = sorted(collect_events(log), key=lambda e: e[0])
        for grp in split_into_sessions(events):
            summary = session_summary(grp, log)
            if summary is not None:
                all_sessions.append(summary)

    local_tz = now.tzinfo
    if not args.all:
        all_sessions = [
            s for s in all_sessions
            if s["start"].astimezone(local_tz).date() == target
        ]

    all_sessions.sort(key=lambda s: s["start"])

    if not all_sessions:
        label = "any day" if args.all else target.isoformat()
        print(f"no sessions found for {label}")
        return 0

    api_key = os.environ.get("ANTHROPIC_API_KEY")
    summarize = bool(api_key) and not args.no_summarize
    caches = {}  # local-date -> cache dict
    dirty = set()

    def cache_for(date):
        if date not in caches:
            caches[date] = load_cache(date)
        return caches[date]

    for s in all_sessions:
        date = s["start"].astimezone(local_tz).date()
        cache = cache_for(date)
        file_entries = cache.get(s["log_path"], {})
        start_iso = s["start"].isoformat()
        end_iso = s["end"].isoformat()
        cached = file_entries.get(start_iso)
        if (cached
                and cached.get("end_ts") == end_iso
                and cached.get("event_count") == s["event_count"]):
            s["name"] = cached["title"]
            continue

        if summarize:
            title = haiku_title(api_key, s["user_texts"])
            if title:
                cache.setdefault(s["log_path"], {})[start_iso] = {
                    "title": title,
                    "end_ts": end_iso,
                    "event_count": s["event_count"],
                }
                dirty.add(date)
                s["name"] = title
                continue

        s["name"] = s["ai_title"] or s["fallback_name"]

    for date in dirty:
        save_cache(date, caches[date])

    proj_w = max(
        (len(project_name(s["cwd"])) for s in all_sessions),
        default=len("PROJECT"),
    )
    proj_w = max(proj_w, len("PROJECT"))
    fixed_w = 16 + 2 + 5 + 2 + 6 + 2 + proj_w + 2  # everything before NAME
    term_w = shutil.get_terminal_size((100, 24)).columns
    name_w = max(20, term_w - fixed_w)
    header = (
        f"{'START':16}  {'END':5}  {'ENG':>6}  "
        f"{'PROJECT':{proj_w}}  NAME"
    )
    rule = "-" * (fixed_w + name_w)
    print(header)
    print(rule)
    total = timedelta(0)
    for s in all_sessions:
        s_local = s["start"].astimezone(local_tz)
        e_local = s["end"].astimezone(local_tz)
        start_str = s_local.strftime("%Y-%m-%d %H:%M")
        end_str = e_local.strftime("%H:%M")
        print(
            f"{start_str:16}  {end_str:5}  {fmt_hhmm(s['engagement']):>6}  "
            f"{project_name(s['cwd']):{proj_w}}  "
            f"{fmt_name(s['name'], name_w)}"
        )
        total += s["engagement"]

    print(rule)
    pad = 16 + 2 + 5 + 2
    print(f"{'total':>{pad}}  {fmt_hhmm(total):>6}  ({len(all_sessions)} sessions)")
    return 0


if __name__ == "__main__":
    sys.exit(main())
